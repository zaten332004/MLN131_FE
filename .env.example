# If your backend is on a different origin than the Vite dev server,
# set the base URL here (no trailing slash). Example:
# VITE_API_BASE_URL=http://localhost:8080
VITE_API_BASE_URL=https://genesis-unda-gemma.ngrok-free.dev

# Optional (dev only): make Vite proxy /api and /hubs to your backend to avoid CORS.
# Example: VITE_API_PROXY_TARGET=http://localhost:8080
VITE_API_PROXY_TARGET=https://genesis-unda-gemma.ngrok-free.dev

# Note: avatarUrl from backend often looks like `/uploads/...`.
# If you leave `VITE_API_BASE_URL` empty, set `VITE_API_PROXY_TARGET` so FE can resolve avatar URLs.
