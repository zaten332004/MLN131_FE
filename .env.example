# This project now runs without a separate backend service.
# Keep these empty so the app does NOT call/proxy to an external BE.
VITE_API_BASE_URL=

# Optional: if you deploy FE on Vercel with `/api/*` proxied server-side,
# keep `VITE_API_BASE_URL` empty (same-origin), but point hubs directly to your backend origin.
# Example: VITE_HUB_BASE_URL=https://api.example.com
VITE_HUB_BASE_URL=

# Optional (dev only): proxy to an external backend (not recommended for this setup).
VITE_API_PROXY_TARGET=

# Gemini API key (set on Vercel as server env var `GEMINI_API_KEY`).
# In local dev, you can set GEMINI_API_KEY too (Vite will not expose it to the browser).
# GEMINI_API_KEY=...

# Note: avatarUrl from backend often looks like `/uploads/...`.
# If you leave `VITE_API_BASE_URL` empty, set `VITE_API_PROXY_TARGET` so FE can resolve avatar URLs.
